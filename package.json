{
  "name": "nostr-crypto-utils",
  "version": "0.7.0",
  "description": "Core cryptographic utilities for Nostr protocol",
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    },
    "./nip44": {
      "types": "./dist/types/nips/nip-44.d.ts",
      "import": "./dist/esm/nips/nip-44.js",
      "require": "./dist/cjs/nips/nip-44.js",
      "default": "./dist/cjs/nips/nip-44.js"
    },
    "./nip46": {
      "types": "./dist/types/nips/nip-46.d.ts",
      "import": "./dist/esm/nips/nip-46.js",
      "require": "./dist/cjs/nips/nip-46.js",
      "default": "./dist/cjs/nips/nip-46.js"
    },
    "./nip49": {
      "types": "./dist/types/nips/nip-49.d.ts",
      "import": "./dist/esm/nips/nip-49.js",
      "require": "./dist/cjs/nips/nip-49.js",
      "default": "./dist/cjs/nips/nip-49.js"
    }
  },
  "files": [
    "dist",
    "src",
    "examples/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:types && npm run build:cjs && npm run build:esm && npm run build:browser",
    "build:types": "tsc -p tsconfig.types.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:browser": "node esbuild.browser.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "nostr",
    "crypto",
    "cryptography",
    "utilities",
    "typescript"
  ],
  "author": "vveerrgg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HumanjavaEnterprises/nostr-crypto-utils.git"
  },
  "bugs": {
    "url": "https://github.com/HumanjavaEnterprises/nostr-crypto-utils/issues"
  },
  "homepage": "https://github.com/HumanjavaEnterprises/nostr-crypto-utils#readme",
  "dependencies": {
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@scure/base": "^2.0.0",
    "assert": "^2.1.0",
    "bech32": "^2.0.0",
    "buffer": "^6.0.3",
    "path-browserify": "^1.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "stream-browserify": "^3.0.0",
    "util": "^0.12.5",
    "vm-browserify": "^1.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
