{
  "name": "nostr-crypto-utils",
  "version": "0.9.2",
  "description": "Core cryptographic utilities for Nostr protocol — edge-native (Cloudflare Workers / Deno / browser), zero non-crypto dependencies",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    },
    "./nip44": {
      "types": "./dist/types/nips/nip-44.d.ts",
      "import": "./dist/esm/nips/nip-44.js",
      "require": "./dist/cjs/nips/nip-44.js",
      "default": "./dist/cjs/nips/nip-44.js"
    },
    "./nip46": {
      "types": "./dist/types/nips/nip-46.d.ts",
      "import": "./dist/esm/nips/nip-46.js",
      "require": "./dist/cjs/nips/nip-46.js",
      "default": "./dist/cjs/nips/nip-46.js"
    },
    "./nip49": {
      "types": "./dist/types/nips/nip-49.d.ts",
      "import": "./dist/esm/nips/nip-49.js",
      "require": "./dist/cjs/nips/nip-49.js",
      "default": "./dist/cjs/nips/nip-49.js"
    },
    "./nip59": {
      "types": "./dist/types/nips/nip-59.d.ts",
      "import": "./dist/esm/nips/nip-59.js",
      "require": "./dist/cjs/nips/nip-59.js",
      "default": "./dist/cjs/nips/nip-59.js"
    },
    "./nip17": {
      "types": "./dist/types/nips/nip-17.d.ts",
      "import": "./dist/esm/nips/nip-17.js",
      "require": "./dist/cjs/nips/nip-17.js",
      "default": "./dist/cjs/nips/nip-17.js"
    },
    "./nip98": {
      "types": "./dist/types/nips/nip-98.d.ts",
      "import": "./dist/esm/nips/nip-98.js",
      "require": "./dist/cjs/nips/nip-98.js",
      "default": "./dist/cjs/nips/nip-98.js"
    }
  },
  "files": [
    "dist",
    "src",
    "examples/**/*",
    "README.md",
    "AGENTS.md",
    "SKILL.md",
    "llms.txt",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:types && npm run build:cjs && npm run build:esm && npm run build:browser",
    "build:types": "tsc -p tsconfig.types.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:browser": "node esbuild.browser.mjs",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "nostr",
    "crypto",
    "cryptography",
    "utilities",
    "typescript",
    "cloudflare-workers",
    "edge",
    "deno",
    "browser",
    "zero-dependency",
    "ai-agent",
    "agentic",
    "sovereign-identity",
    "nip-98",
    "nip-17",
    "nip-59"
  ],
  "author": "vveerrgg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HumanjavaEnterprises/nostr-crypto-utils.git"
  },
  "bugs": {
    "url": "https://github.com/HumanjavaEnterprises/nostr-crypto-utils/issues"
  },
  "homepage": "https://github.com/HumanjavaEnterprises/nostr-crypto-utils#readme",
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/base": "^2.2.0",
    "bech32": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
